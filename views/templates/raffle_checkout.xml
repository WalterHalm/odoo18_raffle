<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Ocultar campo "Nombre de la empresa" del formulario de dirección -->
    <template id="raffle_hide_company_name"
              inherit_id="website_sale.address"
              name="Ocultar Empresa en Checkout">
        <xpath expr="//div[@id='company_name_div']" position="attributes">
            <attribute name="class">col-lg-6 mb-2 d-none</attribute>
        </xpath>
    </template>

    <!-- Agregar botón "Continuar comprando" en la página de pago -->
    <template id="raffle_payment_continue_shopping"
              inherit_id="website_sale.payment"
              name="Botón Continuar Comprando en Pago">
        <xpath expr="//div[@id='o_wsale_total_accordion_item']" position="inside">
            <div class="text-center mt-3">
                <a href="/shop" class="btn btn-outline-secondary w-100">
                    <i class="fa fa-arrow-left me-1"/> Continuar comprando
                </a>
            </div>
        </xpath>
    </template>
</odoo>
