<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_raffle" model="ir.module.category">
        <field name="name">Sorteos</field>
        <field name="sequence">50</field>
    </record>

    <record id="group_raffle_user" model="res.groups">
        <field name="name">Usuario de Sorteos</field>
        <field name="category_id" ref="module_category_raffle"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_raffle_manager" model="res.groups">
        <field name="name">Administrador de Sorteos</field>
        <field name="category_id" ref="module_category_raffle"/>
        <field name="implied_ids" eval="[(4, ref('group_raffle_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- Record Rules -->
    <record id="raffle_rule_user" model="ir.rule">
        <field name="name">Sorteos: usuario ve de su compañía</field>
        <field name="model_id" ref="model_raffle_raffle"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_raffle_user'))]"/>
    </record>

    <record id="raffle_ticket_rule_user" model="ir.rule">
        <field name="name">Tickets: usuario ve de su compañía</field>
        <field name="model_id" ref="model_raffle_ticket"/>
        <field name="domain_force">[('raffle_id.company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_raffle_user'))]"/>
    </record>

    <!-- Reglas para visitantes públicos (solo lectura de sorteos activos) -->
    <record id="raffle_rule_public" model="ir.rule">
        <field name="name">Sorteos: público ve sorteos activos</field>
        <field name="model_id" ref="model_raffle_raffle"/>
        <field name="domain_force">[('state', 'in', ('on_sale', 'completed', 'draw_pending', 'finished', 'delivered'))]</field>
        <field name="groups" eval="[(4, ref('base.group_public'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="raffle_ticket_rule_public" model="ir.rule">
        <field name="name">Tickets: público ve tickets de sorteos activos</field>
        <field name="model_id" ref="model_raffle_ticket"/>
        <field name="domain_force">[('raffle_id.state', 'in', ('on_sale', 'completed', 'draw_pending', 'finished', 'delivered'))]</field>
        <field name="groups" eval="[(4, ref('base.group_public'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Reglas para portal (misma visibilidad que público) -->
    <record id="raffle_rule_portal" model="ir.rule">
        <field name="name">Sorteos: portal ve sorteos activos</field>
        <field name="model_id" ref="model_raffle_raffle"/>
        <field name="domain_force">[('state', 'in', ('on_sale', 'completed', 'draw_pending', 'finished', 'delivered'))]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="raffle_ticket_rule_portal" model="ir.rule">
        <field name="name">Tickets: portal ve tickets de sorteos activos</field>
        <field name="model_id" ref="model_raffle_ticket"/>
        <field name="domain_force">[('raffle_id.state', 'in', ('on_sale', 'completed', 'draw_pending', 'finished', 'delivered'))]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>
