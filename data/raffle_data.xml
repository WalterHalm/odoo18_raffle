<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Ubicación de stock para sorteos -->
        <record id="stock_location_raffles" model="stock.location">
            <field name="name">Sorteos</field>
            <field name="usage">internal</field>
            <field name="location_id" ref="stock.stock_location_locations"/>
            <field name="company_id" ref="base.main_company"/>
        </record>

        <!-- Categoría pública "Rifas" para la tienda online -->
        <record id="raffle_public_category" model="product.public.category">
            <field name="name">Rifas</field>
            <field name="sequence">100</field>
        </record>
    </data>
</odoo>
